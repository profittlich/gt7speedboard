{
    "version" : 2,
    "pages" : [
        {
            "title" : "Page 1",
            "shortcuts" : [ "Key_1" ],
            "list" : [
                {
                    "component" : "LapChangeDetector"
                },
                {
                    "component" : "FuelAnalyzer"
                },
                {
                    "component" : "SessionChangeDetector"
                },
                {
                    "component": "ComparisonLapManager",
                    "configuration": {
                        "maxClosenessDistance": 20
                    }
                },
                {
                    "list" : [
                        {
                            "list" : [
                                {
